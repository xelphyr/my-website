---
import PageLayout from "../layouts/PageLayout.astro";

const pageTitle = "About Me";

const identity = {
    name: "June",
    country: "India",
    pronouns: "she/they/it",
    profession: "college student",
    hobbies: ["guitar", "worldbuilding", "playing Minecraft"],
};

const altIdentity = {
    name: "Joe",
    country: "India",
    pronouns: "he/they",
    profession: "college student",
    hobbies: ["guitar", "worldbuilding", "playing Minecraft"],
};

const skills = ["Godot", "C++", "JS", "Rust?", "Astro"];

const skillColor = "pink";
---

<PageLayout pageTitle={pageTitle}>
    <p>
        Hey there! I'm {altIdentity.name} ({altIdentity.pronouns}), and I'm a {
            altIdentity.profession
        } learning Astro!
    </p>
    <p>
        Two of my hobbies are <b>{altIdentity.hobbies[0]}</b> and <b
            >{altIdentity.hobbies[1]}</b
        >.
    </p>
    <h2>My Skills:</h2>
    <ul>
        {skills.map((skill) => <li class="skill">{skill}</li>)}
    </ul>

    <style is:global define:vars={{ skillColor }}>
        h1 {
            color: purple;
            font-size: 4rem;
        }
        .skill {
            color: var(--skillColor);
            font-weigt: bold;
        }
    </style>
</PageLayout>
